  {
    "test_class": "EventIngestionIntegrationTest (integration)",
    "scenario": "skip_when_scrape_returns_empty",
    "description": "When the (mocked) scrape client returns no events, the DB remains empty and geocode is never called",
    "scrape_returns": [],
    "expected": {
      "status": 200,
      "db_count": 0,
      "geocode_called": false
