{
  "config": {
    "lat": 26.9124,
    "lng": 75.8073
  },
  "scenarios": [
    {
      "name": "happy_path_full_lifecycle",
      "description": "Full lifecycle: report → approve → verify → approve → resolve → approve",
      "steps": [
        {
          "description": "Report an issue",
          "action": "REPORT_ISSUE",
          "actor": "reporter",
          "input": {
            "type": "POTHOLE",
            "description": "Workflow test pothole",
            "mediaType": "PHOTO",
            "mediaUrl": "https://example.com/report-photo.jpg"
          },
          "expect": {
            "httpStatus": 200,
            "issueStatus": "ONHOLD"
          }
        },
        {
          "description": "Anonymous cannot see ONHOLD issue",
          "action": "GET_ISSUE",
          "actor": "anonymous",
          "expect": { "httpStatus": 404 }
        },
        {
          "description": "Other user cannot see ONHOLD issue",
          "action": "GET_ISSUE",
          "actor": "other",
          "expect": { "httpStatus": 404 }
        },
        {
          "description": "Owner sees own ONHOLD issue with media",
          "action": "GET_ISSUE",
          "actor": "reporter",
          "expect": {
            "httpStatus": 200,
            "status": "ONHOLD",
            "mediaCount": 1
          }
        },
        {
          "description": "ONHOLD issue not in public feed",
          "action": "GET_FEED",
          "expect": {
            "httpStatus": 200,
            "issueCount": 0
          }
        },
        {
          "description": "Admin approves REPORT → issue transitions to OPEN",
          "action": "APPROVE_ACTION",
          "input": { "pendingActionType": "REPORT" },
          "expect": {
            "httpStatus": 200,
            "issueStatus": "OPEN"
          }
        },
        {
          "description": "Everyone can now see the OPEN issue",
          "action": "GET_ISSUE",
          "actor": "anonymous",
          "expect": {
            "httpStatus": 200,
            "status": "OPEN",
            "mediaCount": 1,
            "verifyCount": 0
          }
        },
        {
          "description": "OPEN issue appears in public feed",
          "action": "GET_FEED",
          "expect": {
            "httpStatus": 200,
            "issueCount": 1,
            "firstIssueStatus": "OPEN"
          }
        },
        {
          "description": "Reporter verifies with media",
          "action": "VERIFY_ISSUE",
          "actor": "reporter",
          "input": {
            "mediaType": "PHOTO",
            "mediaUrl": "https://example.com/verify-photo.jpg"
          },
          "expect": {
            "httpStatus": 200,
            "issueStatus": "OPEN"
          }
        },
        {
          "description": "Other user cannot see pending verify media or count",
          "action": "GET_ISSUE",
          "actor": "other",
          "expect": {
            "httpStatus": 200,
            "mediaCount": 1,
            "verifyCount": 0
          }
        },
        {
          "description": "Owner sees both REPORT and pending VERIFY media",
          "action": "GET_ISSUE",
          "actor": "reporter",
          "expect": {
            "httpStatus": 200,
            "mediaCount": 2,
            "verifyCount": 0
          }
        },
        {
          "description": "Admin approves VERIFY → verifyCount increments",
          "action": "APPROVE_ACTION",
          "input": { "pendingActionType": "VERIFY" },
          "expect": {
            "httpStatus": 200,
            "issueStatus": "OPEN"
          }
        },
        {
          "description": "Everyone sees 2 media and verifyCount=1",
          "action": "GET_ISSUE",
          "actor": "anonymous",
          "expect": {
            "httpStatus": 200,
            "status": "OPEN",
            "mediaCount": 2,
            "verifyCount": 1
          }
        },
        {
          "description": "Reporter resolves with media",
          "action": "RESOLVE_ISSUE",
          "actor": "reporter",
          "input": {
            "mediaType": "PHOTO",
            "mediaUrl": "https://example.com/resolve-photo.jpg"
          },
          "expect": {
            "httpStatus": 200,
            "issueStatus": "PENDING"
          }
        },
        {
          "description": "Everyone sees status PENDING",
          "action": "GET_ISSUE",
          "actor": "anonymous",
          "expect": {
            "httpStatus": 200,
            "status": "PENDING"
          }
        },
        {
          "description": "Other user sees 2 media (no pending RESOLVE media)",
          "action": "GET_ISSUE",
          "actor": "other",
          "expect": {
            "httpStatus": 200,
            "mediaCount": 2
          }
        },
        {
          "description": "Owner sees all 3 media including pending RESOLVE",
          "action": "GET_ISSUE",
          "actor": "reporter",
          "expect": {
            "httpStatus": 200,
            "mediaCount": 3
          }
        },
        {
          "description": "PENDING issue still in public feed",
          "action": "GET_FEED",
          "expect": {
            "httpStatus": 200,
            "issueCount": 1,
            "firstIssueStatus": "PENDING"
          }
        },
        {
          "description": "Admin approves RESOLVE → issue transitions to RESOLVED",
          "action": "APPROVE_ACTION",
          "input": { "pendingActionType": "RESOLVE" },
          "expect": {
            "httpStatus": 200,
            "issueStatus": "RESOLVED"
          }
        },
        {
          "description": "Everyone sees RESOLVED with all 3 media",
          "action": "GET_ISSUE",
          "actor": "anonymous",
          "expect": {
            "httpStatus": 200,
            "status": "RESOLVED",
            "mediaCount": 3,
            "verifyCount": 1
          }
        },
        {
          "description": "RESOLVED issue still in public feed",
          "action": "GET_FEED",
          "expect": {
            "httpStatus": 200,
            "issueCount": 1,
            "firstIssueStatus": "RESOLVED"
          }
        }
      ]
    },
    {
      "name": "reject_report",
      "description": "Rejecting REPORT action transitions issue to REJECTED",
      "steps": [
        {
          "description": "Report an issue",
          "action": "REPORT_ISSUE",
          "actor": "reporter",
          "input": {
            "type": "POTHOLE",
            "description": "Test rejection",
            "mediaType": "PHOTO",
            "mediaUrl": "https://example.com/report.jpg"
          },
          "expect": { "httpStatus": 200, "issueStatus": "ONHOLD" }
        },
        {
          "description": "Admin rejects REPORT → issue becomes REJECTED",
          "action": "REJECT_ACTION",
          "input": { "pendingActionType": "REPORT" },
          "expect": { "httpStatus": 200, "issueStatus": "REJECTED" }
        },
        {
          "description": "REJECTED issue not in public feed",
          "action": "GET_FEED",
          "expect": { "httpStatus": 200, "issueCount": 0 }
        },
        {
          "description": "REJECTED issue returns 404",
          "action": "GET_ISSUE",
          "actor": "anonymous",
          "expect": { "httpStatus": 404 }
        }
      ]
    },
    {
      "name": "reject_verify",
      "description": "Rejecting VERIFY: issue stays OPEN, verify media/count not visible",
      "steps": [
        {
          "description": "Report an issue",
          "action": "REPORT_ISSUE",
          "actor": "reporter",
          "input": {
            "type": "POTHOLE",
            "description": "Test verify rejection",
            "mediaType": "PHOTO",
            "mediaUrl": "https://example.com/report.jpg"
          },
          "expect": { "httpStatus": 200 }
        },
        {
          "description": "Approve REPORT to open the issue",
          "action": "APPROVE_ACTION",
          "input": { "pendingActionType": "REPORT" },
          "expect": { "httpStatus": 200, "issueStatus": "OPEN" }
        },
        {
          "description": "User verifies the issue",
          "action": "VERIFY_ISSUE",
          "actor": "reporter",
          "input": {
            "mediaType": "PHOTO",
            "mediaUrl": "https://example.com/verify.jpg"
          },
          "expect": { "httpStatus": 200, "issueStatus": "OPEN" }
        },
        {
          "description": "Admin rejects VERIFY → issue stays OPEN",
          "action": "REJECT_ACTION",
          "input": { "pendingActionType": "VERIFY" },
          "expect": { "httpStatus": 200, "issueStatus": "OPEN" }
        },
        {
          "description": "Public sees no verify media/count",
          "action": "GET_ISSUE",
          "actor": "anonymous",
          "expect": { "httpStatus": 200, "verifyCount": 0, "mediaCount": 1 }
        },
        {
          "description": "Owner also sees no rejected verify media",
          "action": "GET_ISSUE",
          "actor": "reporter",
          "expect": { "httpStatus": 200, "verifyCount": 0, "mediaCount": 1 }
        }
      ]
    },
    {
      "name": "reject_resolve",
      "description": "Rejecting RESOLVE: issue reverts to OPEN, resolve media hidden",
      "steps": [
        {
          "description": "Report an issue",
          "action": "REPORT_ISSUE",
          "actor": "reporter",
          "input": {
            "type": "POTHOLE",
            "description": "Test resolve rejection",
            "mediaType": "PHOTO",
            "mediaUrl": "https://example.com/report.jpg"
          },
          "expect": { "httpStatus": 200 }
        },
        {
          "description": "Approve REPORT to open the issue",
          "action": "APPROVE_ACTION",
          "input": { "pendingActionType": "REPORT" },
          "expect": { "httpStatus": 200, "issueStatus": "OPEN" }
        },
        {
          "description": "User resolves the issue",
          "action": "RESOLVE_ISSUE",
          "actor": "reporter",
          "input": {
            "mediaType": "PHOTO",
            "mediaUrl": "https://example.com/resolve.jpg"
          },
          "expect": { "httpStatus": 200, "issueStatus": "PENDING" }
        },
        {
          "description": "Admin rejects RESOLVE → issue reverts to OPEN",
          "action": "REJECT_ACTION",
          "input": { "pendingActionType": "RESOLVE" },
          "expect": { "httpStatus": 200, "issueStatus": "OPEN" }
        },
        {
          "description": "Public sees OPEN with only report media",
          "action": "GET_ISSUE",
          "actor": "anonymous",
          "expect": { "httpStatus": 200, "status": "OPEN", "mediaCount": 1 }
        },
        {
          "description": "Owner also sees no resolve media",
          "action": "GET_ISSUE",
          "actor": "reporter",
          "expect": { "httpStatus": 200, "mediaCount": 1 }
        }
      ]
    },
    {
      "name": "verify_onhold_allowed",
      "description": "VERIFY on ONHOLD issue is allowed — both actions sit in admin queue",
      "steps": [
        {
          "description": "Report an issue (stays ONHOLD)",
          "action": "REPORT_ISSUE",
          "actor": "reporter",
          "input": {
            "type": "POTHOLE",
            "description": "ONHOLD issue",
            "mediaType": "PHOTO",
            "mediaUrl": "https://example.com/report.jpg"
          },
          "expect": { "httpStatus": 200, "issueStatus": "ONHOLD" }
        },
        {
          "description": "Verify on ONHOLD issue succeeds (action is PENDING)",
          "action": "VERIFY_ISSUE",
          "actor": "reporter",
          "input": {
            "mediaType": "PHOTO",
            "mediaUrl": "https://example.com/verify.jpg"
          },
          "expect": { "httpStatus": 200, "issueStatus": "ONHOLD" }
        },
        {
          "description": "Owner sees both report and pending verify media",
          "action": "GET_ISSUE",
          "actor": "reporter",
          "expect": { "httpStatus": 200, "status": "ONHOLD", "mediaCount": 2 }
        },
        {
          "description": "Admin approves REPORT → issue opens",
          "action": "APPROVE_ACTION",
          "input": { "pendingActionType": "REPORT" },
          "expect": { "httpStatus": 200, "issueStatus": "OPEN" }
        },
        {
          "description": "Admin approves VERIFY → verifyCount increments",
          "action": "APPROVE_ACTION",
          "input": { "pendingActionType": "VERIFY" },
          "expect": { "httpStatus": 200, "issueStatus": "OPEN" }
        },
        {
          "description": "Everyone sees 2 media and verifyCount=1",
          "action": "GET_ISSUE",
          "actor": "anonymous",
          "expect": { "httpStatus": 200, "status": "OPEN", "mediaCount": 2, "verifyCount": 1 }
        }
      ]
    },
    {
      "name": "approve_report_reject_verify",
      "description": "User reports and immediately verifies on ONHOLD. Admin approves REPORT but rejects VERIFY — selective approval",
      "steps": [
        {
          "description": "Report an issue",
          "action": "REPORT_ISSUE",
          "actor": "reporter",
          "input": {
            "type": "POTHOLE",
            "description": "Selective approval",
            "mediaType": "PHOTO",
            "mediaUrl": "https://example.com/report.jpg"
          },
          "expect": { "httpStatus": 200, "issueStatus": "ONHOLD" }
        },
        {
          "description": "User immediately verifies while ONHOLD",
          "action": "VERIFY_ISSUE",
          "actor": "reporter",
          "input": {
            "mediaType": "PHOTO",
            "mediaUrl": "https://example.com/verify.jpg"
          },
          "expect": { "httpStatus": 200, "issueStatus": "ONHOLD" }
        },
        {
          "description": "Approve REPORT → issue opens",
          "action": "APPROVE_ACTION",
          "input": { "pendingActionType": "REPORT" },
          "expect": { "httpStatus": 200, "issueStatus": "OPEN" }
        },
        {
          "description": "Admin rejects VERIFY",
          "action": "REJECT_ACTION",
          "input": { "pendingActionType": "VERIFY" },
          "expect": { "httpStatus": 200, "issueStatus": "OPEN" }
        },
        {
          "description": "Issue OPEN, no verify count, only report media",
          "action": "GET_ISSUE",
          "actor": "anonymous",
          "expect": { "httpStatus": 200, "status": "OPEN", "verifyCount": 0, "mediaCount": 1 }
        }
      ]
    },
