    {
      "name": "admin_pending_queue",
      "description": "Admin pending queue contains only PENDING actions",
      "steps": [
        {
          "description": "Report an issue → creates PENDING REPORT action",
          "action": "REPORT_ISSUE",
          "actor": "reporter",
          "input": {
            "type": "POTHOLE",
            "description": "Queue test",
            "mediaType": "PHOTO",
            "mediaUrl": "https://example.com/report.jpg"
          },
          "expect": { "httpStatus": 200 }
        },
        {
          "description": "Pending queue has 1 REPORT action",
          "action": "GET_PENDING",
          "expect": {
            "httpStatus": 200,
            "pendingCount": 1,
            "pendingActions": [
              { "action": "REPORT", "approvalStatus": "PENDING" }
            ]
          }
        },
        {
          "description": "Approve REPORT → pending queue empties",
          "action": "APPROVE_ACTION",
          "input": { "pendingActionType": "REPORT" },
          "expect": { "httpStatus": 200 }
        },
        {
          "description": "Pending queue is now empty",
          "action": "GET_PENDING",
          "expect": { "httpStatus": 200, "pendingCount": 0 }
        }
      ]
    },
