  {
    "test_class": "EventIngestionIntegrationTest (integration)",
    "scenario": "skip_when_scrape_returns_empty",
    "description": "When ScrapeApiClient returns no events, DB stays empty and geocode is never called",
    "scrape_returns": [],
    "expected": {
      "db_count": 0,
      "geocode_called": false
    }
  },
  {
    "test_class": "EventIngestionIntegrationTest (integration)",
    "scenario": "new_event_picked_up_on_second_run",
    "description": "First run imports 1 event. Second run returns the same event + 1 new — only the new one is added, DB ends at 2",
    "first_scrape_returns": [
      {
        "name": "Trek and Plog",
        "start_time": "2026-04-01T09:00:00"
      }
    ],
    "second_scrape_returns": [
      { "name": "Trek and Plog", "start_time": "2026-04-01T09:00:00" },
      { "name": "Beach Cleanup", "start_time": "2026-04-02T09:00:00" }
    ],
    "expected": {
      "db_count_after_first_run": 1,
      "db_count_after_second_run": 2,
      "note": "Simulates the real cron behaviour — only new events are ever inserted"
    }
  }
