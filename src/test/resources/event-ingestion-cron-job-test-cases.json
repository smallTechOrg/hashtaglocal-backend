  {
    "test_class": "EventIngestionIntegrationTest (integration)",
    "scenario": "deduplication_on_repeated_runs",
    "description": "Running the cron job twice with the same scrape data must not create duplicate rows — DB stays at 1 event",
    "scrape_returns": [
      {
        "name": "Trek and Plog",
        "organisation": "Test Org",
        "portal": "Team everest",
        "type": "TREKANDPLOG",
