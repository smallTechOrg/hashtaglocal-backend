[
  {
    "test_class": "EventIngestionCronJobTest (unit)",
    "scenario": "import_and_geocode_called_when_events_returned",
    "description": "When scrape returns events, the pipeline calls import then geocode in order",
    "scrape_returns": [
      { "name": "Trek and Plog", "start_time": "2026-04-01T09:00:00" },
      { "name": "Beach Cleanup", "start_time": "2026-04-02T09:00:00" }
    ],
    "expected": {
      "import_called": true,
      "geocode_called": true,
      "import_receives_exact_list": true
    }
  },
  {
    "test_class": "EventIngestionCronJobTest (unit)",
    "scenario": "skip_import_and_geocode_when_scrape_empty",
    "description": "When scrape returns an empty list, the pipeline exits early — neither import nor geocode is invoked",
    "scrape_returns": [],
    "expected": {
      "import_called": false,
      "geocode_called": false,
      "note": "Early return saves DB writes and Google Maps API quota"
    }
  },
  {
    "test_class": "EventIngestionCronJobTest (unit)",
    "scenario": "geocode_runs_even_when_import_saves_zero",
    "description": "When scrape returns events but all are duplicates (import count = 0), geocode still runs — it may geocode events from previous cycles",
    "scrape_returns": [
      { "name": "Trek and Plog", "start_time": "2026-04-01T09:00:00" }
    ],
    "import_returns": 0,
    "expected": {
      "geocode_called": true,
      "note": "Early return only triggers for an empty scrape list, not for import count = 0"
    }
  },
  {
    "test_class": "EventIngestionCronJobTest (unit)",
    "scenario": "geocode_called_exactly_once",
    "description": "Regardless of how many events are scraped, EventGeocodingService.run() is called exactly once per pipeline run",
    "scrape_returns": [
      { "name": "Event A", "start_time": "2026-04-01T09:00:00" },
      { "name": "Event B", "start_time": "2026-04-02T09:00:00" }
    ],
    "expected": {
      "geocode_invocation_count": 1
    }
  },
  {
    "test_class": "EventIngestionCronJobTest (unit)",
    "scenario": "exact_event_list_passed_to_import",
    "description": "The exact list returned by ScrapeApiClient is forwarded to EventImportService without modification",
    "scrape_returns": [
      { "name": "Trek and Plog", "start_time": "2026-04-01T09:00:00" },
      { "name": "Beach Cleanup", "start_time": "2026-04-02T09:00:00" }
    ],
    "expected": {
      "import_receives": "same list reference as scrape output"
    }
  },
