GOOGLE_APPLICATION_CREDENTIALS=gcs-key.json
FIREBASE_CREDENTIALS_PATH=/opt/hashtaglocal-backend/firebase-key.json

# Event scrape service
EVENTS_SCRAPE_URL=https://staging.api.smalltech.in/webscrapestaging/api/v1/scrape
EVENTS_SCRAPE_CRON=0 */5 * * * *
GOOGLE_MAPS_API_KEY=replacewithrealcreds
GEONAMES_USERNAME=yourusernamehere
GOOGLE_STORAGE_BUCKET_NAME=yourbucketnamehere
APP_FORWARDED_PREFIX=/localstaging

# Slack alert posted to ops when a user reports a new issue (Incoming Webhook URL)
SLACK_ISSUE_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/REAL_WEBHOOK

# Account deletion admin notification
ACCOUNT_DELETION_ADMIN_EMAIL=admin@example.com
ACCOUNT_DELETION_FROM_EMAIL=admin@example.com
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=false
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_SMTP_FROM=admin@example.com
SPRING_MAIL_SMTP_LOCALHOST=example.com
